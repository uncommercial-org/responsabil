{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{- /*
  Custom sitemap with the Google image extension: each page's cover image is
  declared via <image:image> so Google Images can index post covers and LLMs
  get image context. Mirrors Hugo's built-in sitemap otherwise.
*/ -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
  {{- range .Pages }}
  {{- $p := . }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</lastmod>
    {{- end }}
    {{- with .Sitemap.ChangeFreq }}
    <changefreq>{{ . }}</changefreq>
    {{- end }}
    {{- if ge .Sitemap.Priority 0.0 }}
    <priority>{{ .Sitemap.Priority }}</priority>
    {{- end }}
    {{- if .IsTranslated }}
    {{- range .AllTranslations }}
    <xhtml:link rel="alternate" hreflang="{{ .Language.LanguageCode }}" href="{{ .Permalink }}" />
    {{- end }}
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ .Permalink }}" />
    {{- end }}
    {{- with $p.Params.cover.image }}
    {{- $img := cond (eq $p.Params.cover.relative true) (path.Join $p.RelPermalink .) . }}
    <image:image>
      <image:loc>{{ $img | absURL }}</image:loc>
      {{- with $p.Params.cover.alt }}<image:title>{{ . }}</image:title>{{ end }}
    </image:image>
    {{- end }}
  </url>
  {{- end }}
</urlset>
